#!/bin/bash
#
# Release script for VolumePruner
#
# Workflow:
#   1. Build-only (no notarization, no GitHub interaction, no branch checks):
#        bin/release --build-only
#
#   2. Pre-release (build, notarize, upload to GitHub as pre-release):
#        bin/release
#        When on a development branch: branch must be in sync with remote and
#        fast-forward-mergeable into main; CHANGELOG entry must exist for version.
#        When on main: skips branch checks (useful for the very first release).
#
#   3. Full release (merge dev → main, push, promote GitHub pre-release):
#        bin/release --release
#        When on a development branch: squash-merges into main, pushes, promotes.
#        When on main: just pushes main and promotes (no merge needed).
#        Pre-conditions: clean working tree, notarized DMG present.
#
# Append --dry-run to any invocation to preview state-changing actions.
#
# Prerequisites:
#   - Xcode selected:  sudo xcode-select -s /Applications/Xcode.app/Contents/Developer
#   - GitHub CLI:      brew install gh   (and: gh auth login)
#   - create-dmg:      brew install create-dmg
#   - Remote set up:   git remote add origin git@github.com:tinue/VolumePruner.git
#
# Notarization:
#   Store credentials once with:
#     xcrun notarytool store-credentials "notarytool" \
#       --apple-id "your@apple.id" \
#       --team-id "7Q3QN9AV9J" \
#       --password "<app-specific-password>"   # from appleid.apple.com → App-Specific Passwords
#   Then notarization runs automatically.  Set NOTARYTOOL_PROFILE to use a different profile name.
#

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────

PROJECT="VolumePruner.xcodeproj"
SCHEME="VolumePruner"
APP_NAME="VolumePruner"
BUILD_DIR="build/release"
# Optional override; if empty, auto-detect from keychain.
SIGN_IDENTITY="${SIGN_IDENTITY:-}"
NOTARYTOOL_PROFILE="${NOTARYTOOL_PROFILE:-notarytool}"

# Resolve a Developer ID Application identity from keychain unless explicitly set.
if [ -z "$SIGN_IDENTITY" ]; then
    SIGN_IDENTITY=$(security find-identity -v -p codesigning 2>/dev/null \
        | sed -n 's/.*"\(Developer ID Application:.*\)".*/\1/p' \
        | head -n 1)
fi

if [ -z "$SIGN_IDENTITY" ]; then
    echo "Error: No 'Developer ID Application' signing identity found in keychain."
    echo "Install one in Xcode (Settings -> Accounts -> Manage Certificates)"
    echo "or set SIGN_IDENTITY explicitly before running this script."
    exit 1
fi

echo "Using signing identity: $SIGN_IDENTITY"

# ── Argument parsing ───────────────────────────────────────────────────────────

DO_BUILD_ONLY=false
DO_RELEASE=false
DRY_RUN=false

for arg in "$@"; do
    case "$arg" in
        --build-only) DO_BUILD_ONLY=true ;;
        --release)    DO_RELEASE=true ;;
        --dry-run)    DRY_RUN=true ;;
        *) echo "Unknown argument: $arg"; exit 1 ;;
    esac
done

if $DO_BUILD_ONLY && $DO_RELEASE; then
    echo "Error: --build-only and --release are mutually exclusive."
    exit 1
fi

# ── Dry-run helper ─────────────────────────────────────────────────────────────
#
# Wraps state-changing operations (git branch manipulation, GitHub edits).
# Prints the command instead of running it when --dry-run is active.

run_cmd() {
    if $DRY_RUN; then
        echo "[dry-run] $*"
    else
        "$@"
    fi
}

# ── Sanity checks ──────────────────────────────────────────────────────────────

if ! $DO_BUILD_ONLY; then
    if ! command -v gh &>/dev/null; then
        echo "Error: 'gh' CLI not found. Install with: brew install gh"
        exit 1
    fi
fi

if ! $DO_RELEASE; then
    if ! xcode-select -p 2>/dev/null | grep -q "Xcode.app"; then
        echo "Error: Xcode not selected. Run:"
        echo "  sudo xcode-select -s /Applications/Xcode.app/Contents/Developer"
        exit 1
    fi
    if ! command -v create-dmg &>/dev/null; then
        echo "Error: 'create-dmg' not found. Install with: brew install create-dmg"
        exit 1
    fi
fi

# ── 1. Version ─────────────────────────────────────────────────────────────────

VERSION=$(grep -m 1 'MARKETING_VERSION' "$PROJECT/project.pbxproj" \
          | sed -E 's/.*MARKETING_VERSION = ([^;]+);.*/\1/' \
          | tr -d '[:space:]')
TAG="v$VERSION"
DMG_NAME="${APP_NAME}-${VERSION}.dmg"
DMG_PATH="$BUILD_DIR/$DMG_NAME"

# ── 2. Full release: push main, promote GitHub pre-release ────────────────────
#
# --release does not rebuild; it promotes an already-notarized pre-release.
# When on a development branch, squash-merges into main first.
# When already on main, just pushes and promotes.

if $DO_RELEASE; then
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

    # Pre-condition: working tree must be clean
    if ! git diff --quiet; then
        echo "Error: unstaged changes present. Commit or stash them before releasing."
        git status --short
        exit 1
    fi
    if ! git diff --cached --quiet; then
        echo "Error: staged but uncommitted changes present. Commit them before releasing."
        git status --short
        exit 1
    fi

    # Pre-condition: notarized DMG must exist
    if [ ! -f "$DMG_PATH" ]; then
        echo "Error: DMG not found at ${DMG_PATH}."
        echo "  Build and publish a pre-release first: bin/release"
        exit 1
    fi
    echo "Verifying DMG notarization (${DMG_NAME})…"
    if ! xcrun stapler validate "$DMG_PATH" 2>/dev/null; then
        echo "Error: ${DMG_NAME} has not been notarized and stapled."
        echo "  Run: bin/release"
        exit 1
    fi
    echo "DMG notarization OK."

    # Pre-condition: a pre-release must exist on GitHub for this tag
    if ! gh release view "$TAG" &>/dev/null; then
        echo "Error: no GitHub release found for ${TAG}."
        echo "  Build and publish a pre-release first: bin/release"
        exit 1
    fi
    if ! gh release view "$TAG" --json isPrerelease -q .isPrerelease | grep -q true; then
        echo "Error: release ${TAG} exists but is not marked as a pre-release."
        echo "  Nothing to promote."
        exit 1
    fi

    # Confirm CHANGELOG and version have been updated
    echo ""
    read -p "Have CHANGELOG.md and CURRENT_PROJECT_VERSION been updated? (yes/no) " -r
    if [[ ! $REPLY =~ ^[Yy][Ee][Ss]$ ]]; then
        echo "Aborted: Please update CHANGELOG.md and CURRENT_PROJECT_VERSION before releasing."
        exit 1
    fi
    echo ""

    # Read CHANGELOG entry for the squash-merge commit message
    CHANGELOG="CHANGELOG.md"
    COMMIT_MSG="Release ${TAG}"
    if [ -f "$CHANGELOG" ]; then
        ESCAPED_VERSION=$(printf '%s\n' "$VERSION" | sed 's/[.[\*^$/]/\\&/g')
        CHANGELOG_NOTES=$(sed -n "/^## \[${ESCAPED_VERSION}\]/,/^## /p" "$CHANGELOG" | sed '1d;$d' | sed '/^$/d')
        if [ -n "$CHANGELOG_NOTES" ]; then
            COMMIT_MSG="${COMMIT_MSG}"$'\n\n'"${CHANGELOG_NOTES}"
        fi
    fi

    if [ "$CURRENT_BRANCH" = "main" ]; then
        echo "On main — pushing main directly…"
        run_cmd git push origin main
    else
        echo "Merging ${CURRENT_BRANCH} into main (squash)…"
        run_cmd git checkout main
        run_cmd git merge --squash "$CURRENT_BRANCH"
        run_cmd git commit -m "$COMMIT_MSG"
        run_cmd git push origin main
        run_cmd git checkout "$CURRENT_BRANCH"
    fi

    echo "Promoting ${TAG} to full release…"
    run_cmd gh release edit "$TAG" --prerelease=false
    if $DRY_RUN; then
        echo "Done.  [dry-run] No changes made."
    else
        echo "Done.  Release ${TAG}: $(gh release view "${TAG}" --json url -q .url)"
    fi
    exit 0
fi

# ── From here: pre-release or build-only ──────────────────────────────────────

echo "Building $APP_NAME $VERSION (tag: ${TAG})…"

# ── 3. Pre-release pre-conditions ─────────────────────────────────────────────

NOTES=""

if ! $DO_BUILD_ONLY; then
    CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

    # Branch must be clean
    if ! git diff --quiet; then
        echo "Error: unstaged changes present. Commit or stash them before releasing."
        git status --short
        exit 1
    fi
    if ! git diff --cached --quiet; then
        echo "Error: staged but uncommitted changes present. Commit them before releasing."
        git status --short
        exit 1
    fi

    if [ "$CURRENT_BRANCH" != "main" ]; then
        # Branch must be in sync with its remote tracking branch
        UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)
        if [ -z "$UPSTREAM" ]; then
            echo "Error: branch '${CURRENT_BRANCH}' has no remote tracking branch."
            echo "  Push to a remote first: git push -u origin ${CURRENT_BRANCH}"
            exit 1
        fi
        LOCAL_SHA=$(git rev-parse HEAD)
        REMOTE_SHA=$(git rev-parse "$UPSTREAM" 2>/dev/null || true)
        if [ -z "$REMOTE_SHA" ]; then
            echo "Error: could not resolve remote tracking branch '${UPSTREAM}'."
            exit 1
        fi
        if [ "$LOCAL_SHA" != "$REMOTE_SHA" ]; then
            AHEAD=$(git rev-list --count "${UPSTREAM}..HEAD")
            BEHIND=$(git rev-list --count "HEAD..${UPSTREAM}")
            if [ "$AHEAD" -gt 0 ]; then
                echo "Error: ${AHEAD} unpushed commit(s) on '${CURRENT_BRANCH}'. Push before releasing."
            else
                echo "Error: branch '${CURRENT_BRANCH}' is ${BEHIND} commit(s) behind remote. Pull before releasing."
            fi
            exit 1
        fi

        # Branch must be fast-forward-mergeable into main
        git fetch origin main --quiet
        MAIN_SHA=$(git rev-parse origin/main)
        MERGE_BASE=$(git merge-base HEAD origin/main)
        if [ "$MERGE_BASE" != "$MAIN_SHA" ]; then
            echo "Error: branch '${CURRENT_BRANCH}' cannot be fast-forward merged into main."
            echo "  main has commits not present in this branch (e.g. an unmerged patch)."
            echo "  Merge or rebase onto main: git merge origin/main"
            exit 1
        fi
    fi

    # CHANGELOG must have an entry for this version
    CHANGELOG="CHANGELOG.md"
    if [ ! -f "$CHANGELOG" ]; then
        echo "Error: $CHANGELOG not found."
        exit 1
    fi
    ESCAPED_VERSION=$(printf '%s\n' "$VERSION" | sed 's/[.[\*^$/]/\\&/g')
    NOTES=$(sed -n "/^## \[${ESCAPED_VERSION}\]/,/^## /p" "$CHANGELOG" | sed '1d;$d' | sed '/^$/d')
    if [ -z "$NOTES" ]; then
        echo "Error: No changelog entry found for version $VERSION in $CHANGELOG."
        echo "  Add an entry before releasing."
        exit 1
    fi
fi

if $DRY_RUN; then
    echo "Pre-conditions passed.  [dry-run] Build, notarize, and GitHub upload skipped."
    exit 0
fi

# ── 4. Build (archive) ────────────────────────────────────────────────────────

ARCHIVE_PATH="$BUILD_DIR/$APP_NAME.xcarchive"
APP_PATH="$BUILD_DIR/${APP_NAME}.app"

echo "Archiving…"
rm -rf "$BUILD_DIR"
mkdir -p "$BUILD_DIR"

# arch=arm64 in the destination pins the build to Apple Silicon and eliminates
# the "multiple matching destinations" warning that appears when Rosetta is present.
# ARCHS=arm64 ensures the archive itself contains only the arm64 slice.
xcodebuild archive \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Release \
    -destination "platform=macOS,arch=arm64" \
    -archivePath "$ARCHIVE_PATH" \
    ARCHS=arm64 \
    | grep -E "^(Build|Archive|error:|warning:)" \
    | grep -v "provisioning profile" || true
# Note: two-stage grep avoids the BSD grep "repetition-operator operand invalid"
# error that occurs with PCRE lookaheads (?!...) under macOS grep -E.

# ── 5. Export with Developer ID (sign + embed provisioning profile) ───────────
#
# xcodebuild -exportArchive re-signs the app with the Developer ID certificate
# and embeds the matching Developer ID provisioning profile, which is required
# to authorise any entitlements at runtime.  A plain `codesign --force`
# re-signs the binary but keeps the development provisioning profile from the
# archive, causing AMFI to reject entitlements.
#
# -allowProvisioningUpdates lets Xcode automatically download the Developer ID
# provisioning profile from Apple if it is not already installed locally.
# ExportOptions.plist sets method=developer-id and signingStyle=automatic.

EXPORT_DIR="$BUILD_DIR/export"
echo "Exporting with Developer ID…"
xcodebuild -exportArchive \
    -archivePath "$ARCHIVE_PATH" \
    -exportPath "$EXPORT_DIR" \
    -exportOptionsPlist bin/ExportOptions.plist \
    -allowProvisioningUpdates \
    | grep -E "^(Export|error:|warning:)" \
    | grep -v "provisioning profile" || true

APP_EXPORTED="$EXPORT_DIR/${APP_NAME}.app"
if [ ! -d "$APP_EXPORTED" ]; then
    echo "Error: exported .app not found at $APP_EXPORTED"
    echo "Export directory contents:"
    find "$EXPORT_DIR" -maxdepth 3 2>/dev/null || true
    exit 1
fi

cp -R "$APP_EXPORTED" "$APP_PATH"
codesign --verify --deep --strict "$APP_PATH"
echo "Exported and signed: $APP_PATH"

# ── 6. Package as DMG ─────────────────────────────────────────────────────────

echo "Creating DMG…"
CREATE_DMG_LOG=$(mktemp)

run_create_dmg() {
    create-dmg \
        --volname "$APP_NAME $VERSION" \
        --volicon "$APP_PATH/Contents/Resources/AppIcon.icns" \
        --window-pos 200 120 \
        --window-size 660 400 \
        --icon-size 128 \
        --icon "${APP_NAME}.app" 165 185 \
        --app-drop-link 495 185 \
        --no-internet-enable \
        "$DMG_PATH" \
        "$APP_PATH"
}

if ! run_create_dmg >"$CREATE_DMG_LOG" 2>&1; then
    cat "$CREATE_DMG_LOG"

    if grep -Eq "\(-1743\)|Apple[ -]Events.*Finder|Finder.*Apple[ -]Events" "$CREATE_DMG_LOG"; then
        echo ""
        echo "macOS blocked Apple Events automation for Finder (error -1743)."
        echo "Grant permission for iTerm:"
        echo "  1) Open System Settings → Privacy & Security → Automation"
        echo "  2) Select iTerm"
        echo "  3) Enable Finder"
        echo ""
        read -p "After granting permission, press Enter to retry DMG creation (or type 'abort' to stop): " -r RETRY_CREATE_DMG
        if [[ "$RETRY_CREATE_DMG" =~ ^[Aa][Bb][Oo][Rr][Tt]$ ]]; then
            rm -f "$CREATE_DMG_LOG"
            echo "Aborted by user."
            exit 1
        fi

        echo "Retrying DMG creation…"
        : >"$CREATE_DMG_LOG"
        if ! run_create_dmg >"$CREATE_DMG_LOG" 2>&1; then
            cat "$CREATE_DMG_LOG"
            rm -f "$CREATE_DMG_LOG"
            echo "Error: create-dmg failed again after permission prompt."
            exit 1
        fi
    else
        rm -f "$CREATE_DMG_LOG"
        echo "Error: create-dmg failed."
        exit 1
    fi
fi

cat "$CREATE_DMG_LOG"
rm -f "$CREATE_DMG_LOG"

# Sign the DMG itself
codesign --force --sign "$SIGN_IDENTITY" "$DMG_PATH"
echo "DMG: $DMG_PATH"

if $DO_BUILD_ONLY; then
    echo "Done.  Build-only: DMG at ${DMG_PATH}"
    exit 0
fi

# ── 7. Notarize ───────────────────────────────────────────────────────────────

if ! xcrun notarytool history --keychain-profile "$NOTARYTOOL_PROFILE" &>/dev/null; then
    echo "Error: Notarytool profile '$NOTARYTOOL_PROFILE' not found."
    echo "  Run this once to set up:"
    echo "    xcrun notarytool store-credentials \"$NOTARYTOOL_PROFILE\" \\"
    echo "      --apple-id \"your@apple.id\" --team-id 7Q3QN9AV9J \\"
    echo "      --password \"<app-specific-password>\""
    exit 1
fi

echo "Notarizing (this may take a minute)…"
NOTARIZE_OUTPUT=$(xcrun notarytool submit "$DMG_PATH" \
    --keychain-profile "$NOTARYTOOL_PROFILE" \
    --wait 2>&1)
echo "$NOTARIZE_OUTPUT"

NOTARIZE_ID=$(echo "$NOTARIZE_OUTPUT" | grep '^ *id:' | head -1 | sed 's/.*id: *//')
NOTARIZE_STATUS=$(echo "$NOTARIZE_OUTPUT" | grep '^ *status:' | tail -1 | sed 's/.*status: *//')

if [ "$NOTARIZE_STATUS" != "Accepted" ]; then
    echo "Notarization failed (status: $NOTARIZE_STATUS)."
    if [ -n "$NOTARIZE_ID" ]; then
        echo "Fetching rejection log for $NOTARIZE_ID…"
        xcrun notarytool log "$NOTARIZE_ID" --keychain-profile "$NOTARYTOOL_PROFILE"
    fi
    exit 1
fi

xcrun stapler staple "$DMG_PATH"
echo "Notarized and stapled."

# ── 8. GitHub pre-release ─────────────────────────────────────────────────────

if gh release view "$TAG" &>/dev/null; then
    echo "Pre-release ${TAG} exists — updating…"
    gh release edit "$TAG" --notes "$NOTES" --prerelease
    gh release upload "$TAG" "$DMG_PATH" --clobber
else
    echo "Creating GitHub pre-release ${TAG}…"
    gh release create "$TAG" "$DMG_PATH" \
        --title "$APP_NAME $VERSION" \
        --notes "$NOTES" \
        --prerelease
fi

echo "Done.  Pre-release ${TAG}: $(gh release view "${TAG}" --json url -q .url)"
